{
  "name": "ai-provider-lab",
  "version": "0.1.0",
  "description": "Lightweight AI integration patterns for agents: direct providers, CLI agents, and MCP.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "example:list-targets": "npm run build --silent && node dist/examples/list-targets.js",
    "example:inspect-targets": "npm run build --silent && node dist/examples/inspect-targets.js",
    "example:provider-chat": "npm run build --silent && node dist/examples/provider-chat.mock.js",
    "example:mcp-config": "npm run build --silent && node dist/examples/mcp-config.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
